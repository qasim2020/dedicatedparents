<!DOCTYPE html>
<html class="no-js" lang="en">
<head>
    <title>Forgot Password | Dedicated Parents</title>
    {{> header img=meta.img}}
</head>
<body>
    {{> headerNav active='members'}}
    <div class="container">
        <div class="row">
            <div class="col-md-6 col-md-offset-3">
                <div class="page-header"><h2 class="page-title">Forgot Password</h2></div>
                <div class="contact-form">
                    <p>Email</p>
                    <input id="forgotEmail" type="email" class="form-control" placeholder="Email">
                    <button id="forgotBtn" class="mainBtn" style="margin-top:15px;">Send Reset Link</button>
                    <div id="forgotFeedback" style="display:none; margin-top:12px; padding:12px 14px; border-radius:8px;"></div>
                    <p style="margin-top:15px;"><a href="/members/login">Back to login</a></p>
                </div>
            </div>
        </div>
    </div>
    {{> footer}}
    <script>
      document.getElementById('forgotBtn').addEventListener('click', async () => {
        const email = document.getElementById('forgotEmail').value;
        const feedback = document.getElementById('forgotFeedback');

        function showFeedback(message, type) {
          feedback.style.display = 'block';
          feedback.textContent = message;
          if (type === 'success') {
            feedback.style.background = '#edf9ef';
            feedback.style.border = '1px solid #b7e2bf';
            feedback.style.color = '#1f6b2a';
          } else {
            feedback.style.background = '#fff1f1';
            feedback.style.border = '1px solid #efc2c2';
            feedback.style.color = '#932222';
          }
        }

        const res = await fetch('/members/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          showFeedback(data.error || 'Request failed', 'error');
          return;
        }

        showFeedback('If this email exists, a reset link has been sent.', 'success');
      });
    </script>
</body>
</html>
