<!DOCTYPE html>
<html class="no-js" lang="en">
<head>
    <title>Reset Password | Dedicated Parents</title>
    {{> header img=meta.img}}
</head>
<body>
    {{> headerNav active='members'}}
    <div class="container">
        <div class="row">
            <div class="col-md-6 col-md-offset-3">
                <div class="page-header"><h2 class="page-title">Reset Password</h2></div>
                <div class="contact-form">
                    <input id="resetToken" type="hidden" value="{{token}}">
                    <p>New Password</p>
                    <input id="resetPassword" type="password" class="form-control" placeholder="Strong password">
                    <button id="resetBtn" class="mainBtn" style="margin-top:15px;">Reset Password</button>
                    <div id="resetFeedback" style="display:none; margin-top:12px; padding:12px 14px; border-radius:8px;"></div>
                    <p style="margin-top:15px;"><a href="/members/login">Back to login</a></p>
                </div>
            </div>
        </div>
    </div>
    {{> footer}}
    <script>
      document.getElementById('resetBtn').addEventListener('click', async () => {
        const token = document.getElementById('resetToken').value;
        const password = document.getElementById('resetPassword').value;
        const feedback = document.getElementById('resetFeedback');

        function showFeedback(message, type) {
          feedback.style.display = 'block';
          feedback.textContent = message;
          if (type === 'success') {
            feedback.style.background = '#edf9ef';
            feedback.style.border = '1px solid #b7e2bf';
            feedback.style.color = '#1f6b2a';
          } else {
            feedback.style.background = '#fff1f1';
            feedback.style.border = '1px solid #efc2c2';
            feedback.style.color = '#932222';
          }
        }

        const res = await fetch('/members/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, password })
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          showFeedback(data.error || 'Reset failed', 'error');
          return;
        }

        showFeedback('Password reset complete. Signing you in...', 'success');
        window.location.href = data.redirect || '/members/webinars';
      });
    </script>
</body>
</html>
