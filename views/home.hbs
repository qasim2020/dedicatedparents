<!DOCTYPE html>
<!--[if lt IE 7]> 
<html class="no-js lt-ie9 lt-ie8 lt-ie7" lang="en">
    <![endif]-->
    <!--[if IE 7]> 
    <html class="no-js lt-ie9 lt-ie8" lang="en">
        <![endif]-->
        <!--[if IE 8]> 
        <html class="no-js lt-ie9" lang="en">
            <![endif]-->
            <!--[if gt IE 8]><!--> 
            <html class="no-js" lang="en">
                <!--<![endif]-->
                <head>
                    <title>Dedicated Parents | Home</title>
                    {{> header img=meta.img}}
                </head>
                <body>
                    {{> headerNav active='home'}}
                    <div class="container">
                        <div class="top-content">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="u-cause-wrapper hidden-xs">
                                        <span class="u-cause-title">
                                            <a href="#" class="close-u-cause"> <i class="fa fa-times"></i> </a> 
                                            OUR UPDATES 
                                        </span>
                                        <div class="u-cause clearfix">
                                            <dl class="inner-carousel clearfix">
                                                {{#each causes}}
                                                <dt></dt>
                                                <dd>
                                                    <a href="/cause/{{this.slug}}">{{this.title}}</a> |
                                                    {{this.summary}}
                                                </dd>
                                                {{/each}}
                                                {{#each futureThreeEvents}}
                                                <dt></dt>
                                                <dd>
                                                    <a href="/event/{{this.slug}}">{{this.title}}</a> | 
                                                    {{this.summary}}
                                                </dd>
                                                {{/each}}
                                                {{#each events}}
                                                <dt></dt>
                                                <dd>
                                                    <a href="/event/{{this.slug}}">{{this.title}}</a> | 
                                                    {{this.summary}}
                                                </dd>
                                                {{/each}}
                                            </dl>
                                            <!-- /.inner-carousel -->
                                        </div>
                                        <!-- /.u-cause -->
                                    </div>
                                    <!-- /.u-cause-wrapper -->
                                </div>
                                <!-- /.col-md-12 -->
                            </div>
                            <!-- /.row -->
                            <div class="slider-wrapper">
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="flexslider">
                                            <ul class="slides">
                                                {{#each futureThreeEvents}}
                                                <li>
                                                    <img src="{{cloudinaryTransformation this.bannerImg 826 1155}}" alt="">
                                                    <div class="flex-caption">
                                                        <p>
                                                            {{this.summary}}
                                                            <a href="/event/{{this.slug}}">Read More</a>
                                                        </p>
                                                    </div>
                                                </li>
                                                {{/each}}
                                                {{#each events}}
                                                <li>
                                                    <img src="{{cloudinaryTransformation this.bannerImg 826 1155}}" alt="">
                                                    <div class="flex-caption">
                                                        <p>
                                                            {{this.summary}}
                                                            <a href="/event/{{this.slug}}">Read More</a>
                                                        </p>
                                                    </div>
                                                </li>
                                                {{/each}}
                                            </ul>
                                        </div>
                                        <!-- /.flexslider -->
                                    </div>
                                    <div class="col-md-4">
                                        <div class="subscribe-form" style="padding-right: 52px">
                                            <h3 class="widget-title">Stay up to date</h3>
                                            <p>Sign up today for our e-newsletter to find out what is going on and get involved.</p>
                                            <form>
                                                <fieldset>
                                                    <label for="name">First Name:</label>
                                                    <input type="text" id="name" name="name" class="form-input">
                                                </fieldset>
                                                <fieldset>
                                                    <label for="last-name">Last Name:</label>
                                                    <input type="text" id="last-name" name="last-name" class="form-input">
                                                </fieldset>
                                                <fieldset>
                                                    <label for="email">Email:</label>
                                                    <input type="email" id="email" name="email" class="form-input">
                                                </fieldset>
                                                <fieldset>
                                                    <button type="submit" id="send-button" class="btn main-btn">Submit</button>
                                                </fieldset>
                                            </form>
                                        </div>
                                        <!-- /.subscribe-form -->
                                    </div>
                                    <!-- /.col-md-4 -->

                                    <!-- /.col-md-8 -->
                                </div>
                                <!-- /.row -->
                            </div>
                            <!-- /.slider-wrapper -->
                        </div>
                        <!-- /.top-content -->
                        <div class="services box-content">
                            <div class="row">
                                <div class="col-md-offset-2 col-md-8 services-header">
                                    <h5 class="widget-title">Welcome to Dedicated Parents</h5>
                                    <span></span>
                                    <p>On a journey to craft harmonious homes and flourishing futures, where wisdom lights our way and compassion fuels our choices.</p>
                                </div>
                                <!-- /.services-header -->
                            </div>
                            <!-- /.row -->
                            <div class="row">
                                <div class="col-md-4 service-item">
                                    <div class="service-icon">
                                        <i class="fa fa-globe"></i>
                                    </div>
                                    <div class="service-content">
                                        <h4 class="service-title">{{threePages.education.title}}</h4>
                                        <p>{{threePages.education.subtitle}}</p>
                                        <a href="/page/{{threePages.education.slug}}" class="read-more"></a>Read More &rarr;</a>
                                    </div>
                                </div>
                                <!-- /.service-item -->
                                <div class="col-md-4 service-item">
                                    <div class="service-icon">
                                        <i class="fa fa-umbrella"></i>
                                    </div>
                                    <div class="service-content">
                                        <h4 class="service-title">{{threePages.helpAndSupport.title}}</h4>
                                        <p>{{threePages.helpAndSupport.subtitle}}.</p>
                                        <a href="/page/{{threePages.helpAndSupport.slug}}" class="read-more">Read More &rarr;</a>
                                    </div>
                                </div>
                                <!-- /.service-item -->
                                <div class="col-md-4 service-item">
                                    <div class="service-icon">
                                        <i class="fa fa-group"></i>
                                    </div>
                                    <div class="service-content">
                                        <h4 class="service-title">{{threePages.volunteering.title}}</h4>
                                        <p>{{threePages.volunteering.subtitle}}.</p>
                                        <a href="/page/{{threePages.volunteering.slug}}" class="read-more">Read More &rarr;</a>
                                    </div>
                                </div>
                                <!-- /.service-item -->
                            </div>
                            <!-- /.row -->
                        </div>
                        <!-- /.services -->
                        <div class="last-causes box-content">
                            <div class="row">
                                <div class="col-md-12">
                                    <h4 class="widget-title"><span>Last Cause List</span></h4>
                                </div>
                                <!-- /.col-md-12 -->
                            </div>
                            <!-- /.row -->
                            <div class="row">
                                {{#each causes}}
                                <div class="col-md-3 col-sm-6 cause-grid">
                                    <div class="cause-thumb">
                                        <!-- <img src="http://placehold.it/255x200" alt=""> -->
                                        <img src="https://res.cloudinary.com/miscellaneous/image/upload/c_lpad,h_200,w_255/{{this.number}}/dedicatedparents/causes-photos/{{this.imgSlug}}" alt="">
                                        <div class="cause-hover">
                                            <div class="cause-holder clearfix">
                                                <div class="progress">
                                                    <div class="progress-bar" role="progressbar" aria-valuenow="{{this.percent}}" aria-valuemin="0" aria-valuemax="100" style="width: {{this.percent}}%;"></div>
                                                </div>
                                                <span class="raised pull-left">{{this.raised}}</span>
                                                <span class="goal pull-right">{{this.target}}</span>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- /.cause-thumb -->
                                    <div class="cause-content">
                                        <h4 class="cause-title"><a href="/cause/{{this.slug}}">{{this.title}}</a></h4>
                                        <p>{{this.summary}}</p>                                        
                                    </div>
                                    <!-- /.cause-content -->
                                </div>
                                {{/each}}

                            </div>
                            <!-- /.row -->
                        </div>
                        <!-- /.last-causes -->
                        <div class="row">
                            <div class="col-md-8">
                                <div class="box-content">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <h4 class="widget-title"><span>Membership</span></h4>
                                        </div>
                                    </div>
                                    <div class="row" style="padding: 20px;">
                                        <div class="col-md-12 text-center" style="margin-bottom: 20px;">
                                            <h3 style="font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #333;">Transform with Dedicated Parents</h3>
                                            <hr style="width: 80px; border-top: 3px solid #f0c247; margin: 15px auto;">
                                        </div>

                                        <div class="col-md-6">
                                            <h4 style="font-weight: 600; color: #333; margin-bottom: 15px;">As a Member You Get</h4>
                                            <ul style="list-style: none; padding: 0; margin: 0 0 20px 0;">
                                                <li style="padding: 8px 0; border-bottom: 1px solid #eee;">
                                                    <i class="fa fa-check-circle" style="color: #f0c247; margin-right: 10px;"></i>15% Discount on All Courses
                                                </li>
                                                <li style="padding: 8px 0; border-bottom: 1px solid #eee;">
                                                    <i class="fa fa-check-circle" style="color: #f0c247; margin-right: 10px;"></i>25% Discount on Relationship Therapy Sessions
                                                </li>
                                                <li style="padding: 8px 0; border-bottom: 1px solid #eee;">
                                                    <i class="fa fa-check-circle" style="color: #f0c247; margin-right: 10px;"></i>Monthly Newsletter
                                                </li>
                                                <li style="padding: 8px 0;">
                                                    <i class="fa fa-check-circle" style="color: #f0c247; margin-right: 10px;"></i>Private Community and Support Group
                                                </li>
                                            </ul>
                                            <p style="color: #555; line-height: 1.7;">
                                                Join us today and be a part of the Dedicated Parents family! Together, we'll shape a brighter future for our children and generations to come.
                                            </p>
                                            <p style="font-weight: 600; color: #333; font-style: italic;">Let's thrive together!</p>
                                        </div>

                                        <div class="col-md-6">
                                            <h4 style="font-weight: 600; color: #333; margin-bottom: 15px;">What We Offer</h4>
                                            <div style="background: #f9f9f9; border-left: 4px solid #f0c247; padding: 15px 20px; margin-bottom: 12px; border-radius: 3px;">
                                                <i class="fa fa-graduation-cap" style="color: #f0c247; margin-right: 10px;"></i>
                                                <strong>Parenting &amp; Professional Courses</strong>
                                            </div>
                                            <div style="background: #f9f9f9; border-left: 4px solid #f0c247; padding: 15px 20px; margin-bottom: 12px; border-radius: 3px;">
                                                <i class="fa fa-book" style="color: #f0c247; margin-right: 10px;"></i>
                                                <strong>Newsletters &amp; Ebooks</strong>
                                            </div>
                                            <div style="background: #f9f9f9; border-left: 4px solid #f0c247; padding: 15px 20px; margin-bottom: 12px; border-radius: 3px;">
                                                <i class="fa fa-heart" style="color: #f0c247; margin-right: 10px;"></i>
                                                <strong>Relationship Therapy Sessions</strong>
                                            </div>
                                            <div style="background: #f9f9f9; border-left: 4px solid #f0c247; padding: 15px 20px; margin-bottom: 12px; border-radius: 3px;">
                                                <i class="fa fa-users" style="color: #f0c247; margin-right: 10px;"></i>
                                                <strong>Private Community &amp; Support Group</strong>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- /.row -->
                                </div>
                                <!-- /.box-content -->
                                <div class="box-content">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <h4 class="widget-title"><span>Our team members</span></h4>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-12 testimonials-wrapper">
                                            <ul class="testi-tabs clearfix">
                                            {{#each staffs}}
                                                <li {{#if (matchValues @index 0)}} class="active" {{/if}}>
                                                    <a href="#testi-content-0{{inc @index}}">
                                                    <img src="https://res.cloudinary.com/miscellaneous/image/upload/c_lpad,h_70,w_70/v1680079430/dedicatedparents/team-photos/{{this.image}}" alt="">
                                                    </a>
                                                </li>
                                            {{/each}}
                                            </ul>
                                            <div class="testi-wrapper">
                                                {{#each staffs}}
                                                <div id="testi-content-0{{inc @index}}" class="testi-content {{#if (matchValues @index 0)}}active{{/if}}">
                                                    <div class="testi-author">
                                                        <h6>{{this.title}}<span>{{this.role}}</span></h6>
                                                    </div>
                                                    <p>
                                                        {{reduceStringLength this.detail '151'}}...
                                                    </p>
                                                    <a href="/team-member/{{this.slug}}">Read More...</a>
                                                </div>
                                                {{/each}}
                                            </div>
                                            <!-- //.testi-wrapper -->
                                        </div>
                                        <!-- /.col-md-12 -->
                                    </div>
                                    <!-- /.row -->
                                </div>
                                <!-- /.box-content -->
                            </div>
                            <!-- /.col-md-8 -->
                            <div class="col-md-4">
                                {{> galleryPhotos}}
                                {{> upcomingEvents}}
                            </div>
                        </div>
                    </div>
                    {{> footer}}
                </body>
            </html>
